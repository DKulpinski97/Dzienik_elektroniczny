@using Microsoft.AspNetCore.Identity;
@{
    ViewData["Title"] = "Zarządzanie rolami";
}
<div class="container mt-5">
    <div class="row g-4" style="min-height: 75vh;">

        <div class="col d-flex">
            <div class="border rounded p-4 w-100">
                <h2 class="text-center">Admin</h2>
                @if (ViewBag.Komunikat != null)
                {
                    <div class="alert alert-danger">
                        @ViewBag.Komunikat
                    </div>
                }
                @using (Html.BeginForm("DodajRole", "Admin", FormMethod.Post))
                {
                    @Html.TextBox("NazwaRoli","",new{@class = "form-control",placeholder = "np. Nauczyciel"})
                  

                    @Html.AntiForgeryToken()

                    <button type="submit">
                        Dodaj rolę
                    </button>
                }
            </div>
        </div>


        <div class="col d-flex">
            <div class="border rounded p-4 w-100">
                <h2 class="text-center">Rodzic</h2>

                @model List<IdentityRole>

                @Html.ListBox(
                    "RoleId",
                    new SelectList(Model, "Id", "Name"),
                    new { @class = "form-select", size = 5 }
                )
            </div>
        </div>
    </div>
</div>